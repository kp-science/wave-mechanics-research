<!DOCTYPE html>
<html lang="th"><head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>EP06 · P24 · KEPLER GAUNTLET (Boss)</title>
<link rel="stylesheet" href="../shared/book.css?v=6">
<link rel="stylesheet" href="_page-style.css">
<style>
.boss-stage { position:relative; height:240px; background:radial-gradient(circle at 30% 50%, rgba(185,128,255,0.45), rgba(58,10,74,0.5) 60%, #02030a 90%); border-radius:14px; overflow:hidden; margin:8px 0; }
.boss-void { position:absolute; left:25%; top:50%; transform:translate(-50%,-50%); width:120px; height:120px; border-radius:50%;
            background:radial-gradient(circle at 40% 40%, #b980ff 20%, #5a30a0 60%, #1a0830);
            box-shadow:0 0 60px #b980ff, inset 0 0 40px #6a30a0; animation:bossSpin 8s linear infinite, bossBreath 2s ease-in-out infinite; }
@keyframes bossSpin { from{filter:hue-rotate(0);} to{filter:hue-rotate(360deg);} }
@keyframes bossBreath { 0%,100%{transform:translate(-50%,-50%) scale(1);} 50%{transform:translate(-50%,-50%) scale(1.05);} }
.cme-pulse { position:absolute; left:25%; top:50%; transform:translate(-50%,-50%); width:120px; height:120px; border-radius:50%;
             border:3px solid #ff5c7a; opacity:0; pointer-events:none; }
.cme-pulse.fire { animation:cmeP 1s ease-out forwards; }
@keyframes cmeP { 0%{opacity:1;width:120px;height:120px;} 100%{opacity:0;width:480px;height:480px;} }
.player-ship { position:absolute; right:10%; top:50%; transform:translate(50%,-50%); font-size:32px; filter:drop-shadow(0 0 10px #64d8ff); transition:transform .2s; }
.boss-hud { display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; padding:10px; border-radius:12px; background:rgba(20,8,16,0.85); border:1px solid #ff5c7a; margin:8px 0; }
.hud-cell { padding:8px; border-radius:8px; background:rgba(0,0,0,.4); text-align:center; }
.hud-cell .lbl { font-family:Orbitron,monospace; font-size:10px; color:#9aa3c0; letter-spacing:.14em; }
.hud-cell .val { font-family:Orbitron,monospace; font-size:18px; font-weight:700; }
.hud-cell.energy .val { color:#7effb2; }
.hud-cell.thrust .val { color:#ffcb6b; }
.hud-cell.cd .val { color:#ff5c7a; }
.q-area { padding:14px; border-radius:12px; background:rgba(20,28,52,0.7); border:1px solid rgba(185,128,255,0.4); margin:8px 0; min-height:140px; }
.q-area .qtxt { font-size:14px; color:#b980ff; margin-bottom:10px; line-height:1.6; }
.q-choice { display:flex; gap:8px; }
.q-choice button { flex:1; padding:14px; font-size:13px; }
.zone-tag { display:inline-block; padding:4px 10px; border-radius:999px; font-family:Orbitron,monospace; font-size:11px; letter-spacing:.12em; margin-bottom:6px; }
.zone-tag.z1 { background:rgba(185,128,255,.2); color:#b980ff; border:1px solid #b980ff; }
.zone-tag.z2 { background:rgba(255,203,107,.2); color:#ffcb6b; border:1px solid #ffcb6b; }
.zone-tag.z3 { background:rgba(126,255,178,.2); color:#7effb2; border:1px solid #7effb2; }
.thrust-bar { height:10px; border-radius:5px; background:rgba(255,255,255,.1); overflow:hidden; margin-top:4px; }
.thrust-bar .fill { height:100%; background:linear-gradient(90deg, #ffcb6b, #7effb2); transition:width .4s; }
.dmg-pop { position:absolute; pointer-events:none; font-family:Orbitron,monospace; font-weight:700; font-size:20px; animation:dmgPop 1s forwards; z-index:200; }
@keyframes dmgPop { 0%{opacity:0;transform:translateY(0);} 20%{opacity:1;transform:translateY(-10px);} 100%{opacity:0;transform:translateY(-60px);} }
</style>
</head>
<body data-page="p24" data-type="mixed">
<div class="page">
  <span class="lbl mixed">🔥 BOSS · KEPLER GAUNTLET</span>
  <h1 style="color:#b980ff;">KEPLER GAUNTLET</h1>
  <div class="muted">3 waves · pool 24 ข้อ · 24 ชม. countdown</div>

  <div class="boss-stage" id="stage">
    <div class="boss-void" id="void"></div>
    <div class="cme-pulse" id="pulse"></div>
    <div class="player-ship" id="ship">🚀</div>
  </div>

  <div class="boss-hud">
    <div class="hud-cell energy"><div class="lbl">⚡ ENERGY</div><div class="val" id="hudEnergy">100</div></div>
    <div class="hud-cell thrust"><div class="lbl">🚀 THRUST</div><div class="val" id="hudThrust">0/30</div></div>
    <div class="hud-cell cd"><div class="lbl">⏰ CME-ETA</div><div class="val" id="hudCD">24h</div></div>
  </div>

  <div id="powerBar" style="display:flex; gap:6px; margin:6px 0; flex-wrap:wrap; justify-content:center;"></div>
  <div class="thrust-bar"><div class="fill" id="thrustFill" style="width:0%;"></div></div>
  <div style="margin-top:6px;"><span class="zone-tag z1" id="zoneTag">Wave 1 · Inner + Nebula + Disk</span></div>

  <div class="q-area" id="qArea">
    <div class="qtxt" id="qTxt">— กดเริ่ม —</div>
    <div class="q-choice" id="qChoice"></div>
  </div>
  <button id="startBtn">▶ START KEPLER GAUNTLET</button>

  <div class="card" id="endCard" style="display:none;">
    <h3 id="endTitle"></h3>
    <div id="endBody"></div>
  </div>

  <details class="tc"><summary>🎓 Teacher Cue · P24</summary>
    <div>3 waves · 8 ข้อ/wave · meteor pulse ทุก 14 วิ -6 energy · ตอบถูก +10/+15 thrust · Energy ≥70+lance = A+, ≥40 = A, ≥1 = B, =0 = C</div></details>

  <div class="btn-pair">
    <button class="submit-btn" disabled style="opacity:.5;">— auto-submit เมื่อจบ —</button>
    <button class="next-btn" id="nextBtn" disabled>🔒 ต้องจบ boss ก่อน</button>
  </div>
</div>

<script src="../shared/firebase-config.js"></script>
<script src="./config.js"></script>
<script src="../../shared/pace-client.js"></script>
<script src="../shared/sync-client.js"></script>
<script src="../shared/photon.js?v=3"></script>
<script src="../shared/role-view.js"></script>
<script src="../shared/starfield.js?v=1"></script>
<script src="../shared/audio.js?v=2"></script>
<script src="../shared/mission-brief.js?v=1"></script>
<script src="../shared/mystery-box.js?v=2"></script>
<script src="../shared/kpa-tracker.js?v=1"></script>
<script src="../shared/pause-card.js?v=1"></script>
<script src="../shared/group-talk.js?v=1"></script>
<script src="../shared/explain-back.js?v=1"></script>
<script src="../shared/confidence-gate.js?v=1"></script>
<script src="../shared/learning-journal.js?v=1"></script>
<script src="../shared/reveal-after-submit.js?v=1"></script>
<script src="../shared/ep06-boot.js?v=1"></script>
<script>
const cfg = EP_CONFIG.boss;
let energy = cfg.startEnergy;
let countdownHr = cfg.startCountdownHr;
let zone = 1;
let thrust = 0;
let pool = [];
let chargeInterval = null;
let ended = false;
let answered = 0;

const POWERS = Chain.get('bossPowers') || {};
let blastAvailable = !!POWERS.blast;
let autoTargetAvailable = !!POWERS.autoTarget;
let shieldAvailable = !!POWERS.shield;
let deflectAvailable = !!POWERS.deflect;
let burstAvailable = !!POWERS.burst;
let slowTimeAvailable = !!POWERS.slowTime;
const lanceUnlocked = !!POWERS.lanceUnlock;

function renderPowerBar(){
  const bar = document.getElementById('powerBar'); bar.innerHTML='';
  const items = [
    { id:'blast', avail:blastAvailable, ic:'💥', n:'BLAST', action:useBlast },
    { id:'autoTarget', avail:autoTargetAvailable, ic:'🎯', n:'AUTO TARGET', action:useAutoTarget },
    { id:'shield', avail:shieldAvailable, ic:'🛡️', n:'SHIELD', action:null },
    { id:'deflect', avail:deflectAvailable, ic:'↩️', n:'DEFLECT', action:null },
    { id:'burst', avail:burstAvailable, ic:'⚡', n:'BURST', action:null },
    { id:'slowTime', avail:slowTimeAvailable, ic:'⏱️', n:'SLOW-TIME', action:useSlowTime },
    { id:'lance', avail:lanceUnlocked, ic:'🗡️', n:'GENESIS LANCE', action:null, persistent:true },
  ];
  items.forEach(it => {
    if(!POWERS[it.id] && it.id !== 'lance') return;
    if(it.id==='lance' && !lanceUnlocked) return;
    const used = !it.avail;
    const clickable = !!it.action && it.avail;
    const el = document.createElement('div');
    el.style.cssText = `padding:5px 9px; border-radius:8px; border:1px solid ${used?'rgba(120,140,220,0.3)':'#7effb2'}; background:${used?'rgba(20,28,52,0.5)':'rgba(126,255,178,0.12)'}; font-family:Orbitron,monospace; font-size:10px; color:${used?'#6a7394':'#7effb2'}; ${clickable?'cursor:pointer;':''}`;
    const status = it.persistent ? 'A+' : (used ? 'USED' : (clickable ? 'TAP' : 'AUTO'));
    el.innerHTML = `${it.ic} ${it.n} · ${status}`;
    if(clickable) el.onclick = it.action;
    bar.appendChild(el);
  });
}

function useBlast(){ if(!blastAvailable) return; blastAvailable=false; thrust+=5; flash('+5 BLAST','#7effb2'); updateHud(); renderPowerBar(); }
function useAutoTarget(){
  if(!autoTargetAvailable) return; autoTargetAvailable=false;
  if(window._currentQ){
    const ch = document.getElementById('qChoice'); const c = window._currentQ.c;
    [...ch.children].forEach((b,i) => { if(i===c){ b.style.background='rgba(126,255,178,0.25)'; b.style.borderColor='#7effb2'; } else b.style.opacity='0.5'; });
  }
  flash('🎯 AUTO TARGET','#7effb2'); renderPowerBar();
}
function useSlowTime(){ if(!slowTimeAvailable) return; slowTimeAvailable=false; countdownHr+=6; flash('⏱️ +6h','#ff8a3d'); updateHud(); renderPowerBar(); }

function shuffle(a){ return a.slice().sort(()=>Math.random()-0.5); }
function loadZonePool(z){
  pool = shuffle(cfg.pools['zone'+z]);
  document.getElementById('zoneTag').className = 'zone-tag z'+z;
  document.getElementById('zoneTag').textContent = ['Wave 1 · Inner + Nebula + Disk','Wave 2 · Belt + Giants','Wave 3 · Kuiper + Oort + Heliopause + Habitable'][z-1];
}
function updateHud(){
  document.getElementById('hudEnergy').textContent = Math.max(0,Math.round(energy));
  document.getElementById('hudThrust').textContent = thrust+'/'+cfg.thrustPerZone;
  document.getElementById('hudCD').textContent = Math.max(0,countdownHr)+'h';
  document.getElementById('thrustFill').style.width = Math.min(100, thrust/cfg.thrustPerZone*100)+'%';
}
function showQ(){
  if(ended) return;
  if(!pool.length) loadZonePool(zone);
  const q = pool.shift(); if(!q){ loadZonePool(zone); return showQ(); }
  window._currentQ = q;
  document.getElementById('qTxt').innerHTML = q.q+' <span style="font-size:11px;color:#9aa3c0;">['+q.tier+']</span>';
  const ch = document.getElementById('qChoice'); ch.innerHTML='';
  q.a.forEach((t,i) => {
    const b = document.createElement('button'); b.textContent = t;
    b.onclick = () => answer(i, q);
    ch.appendChild(b);
  });
  renderPowerBar();
}
function answer(i, q){
  answered++; countdownHr -= cfg.countdownPerAnswer;
  if(i===q.c){
    const t = q.tier==='hard' ? cfg.thrustHard : cfg.thrustEasy;
    thrust += t;
    if(window.SFX) SFX.play('correct');
    flash('+'+t+' THRUST','#7effb2');
    if(thrust >= cfg.thrustPerZone){
      thrust=0;
      if(zone < 3){ zone++; Chain.set('bossWave',zone); loadZonePool(zone); flashBig('WAVE '+zone+' →'); }
      else return endBoss();
    }
  } else {
    if(burstAvailable){
      burstAvailable = false;
      const t = Math.max(1, Math.floor(cfg.thrustEasy/2));
      thrust += t;
      flash('⚡ BURST · +'+t,'#ffcb6b');
      renderPowerBar();
    } else if(deflectAvailable){
      deflectAvailable = false;
      flash('↩️ DEFLECT · 0','#64d8ff');
      renderPowerBar();
    } else {
      energy += cfg.thrustWrong;
      if(energy<0) energy=0;
      if(window.SFX) SFX.play('wrong');
      flash(cfg.thrustWrong+' ENERGY','#ff5c7a');
    }
  }
  updateHud();
  if(countdownHr<=0 || energy<=0) return endBoss();
  showQ();
}
function flash(txt, color){
  const stage = document.getElementById('stage');
  const p = document.createElement('div'); p.className='dmg-pop'; p.textContent=txt; p.style.color=color;
  p.style.left = (50+Math.random()*30)+'%'; p.style.top='30%';
  stage.appendChild(p); setTimeout(()=>p.remove(),1000);
}
function flashBig(txt){
  const o = document.createElement('div');
  o.style.cssText='position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.6);z-index:300;font-family:Orbitron,monospace;font-size:42px;color:#b980ff;letter-spacing:.2em;text-shadow:0 0 30px #b980ff;pointer-events:none;animation:zoneIn 1.4s forwards;';
  o.textContent = txt;
  document.body.appendChild(o);
  if(!document.getElementById('zoneInStyle')){
    const s=document.createElement('style'); s.id='zoneInStyle';
    s.textContent='@keyframes zoneIn { 0%{opacity:0;transform:scale(0.5);} 30%{opacity:1;transform:scale(1);} 70%{opacity:1;} 100%{opacity:0;transform:scale(1.4);} }';
    document.head.appendChild(s);
  }
  setTimeout(()=>o.remove(),1400);
}
function fireCharge(){
  if(ended) return;
  if(shieldAvailable){
    shieldAvailable=false;
    flash('🛡️ SHIELD · 0','#7effb2');
    document.getElementById('pulse').classList.remove('fire');
    void document.getElementById('pulse').offsetWidth;
    document.getElementById('pulse').classList.add('fire');
    renderPowerBar();
    return;
  }
  energy -= cfg.chargeDamage;
  if(energy<0) energy=0;
  document.getElementById('pulse').classList.remove('fire');
  void document.getElementById('pulse').offsetWidth;
  document.getElementById('pulse').classList.add('fire');
  flash('-'+cfg.chargeDamage+' ENERGY','#ff5c7a');
  updateHud();
  if(energy<=0) endBoss();
}
function startCharge(){
  chargeInterval = setInterval(fireCharge, cfg.chargeIntervalSec*1000);
}
function endBoss(){
  if(ended) return;
  ended = true;
  clearInterval(chargeInterval);
  document.getElementById('qArea').style.display='none';
  document.getElementById('startBtn').style.display='none';
  let ending;
  if(energy >= cfg.endingThresholds['A+'] && lanceUnlocked) ending='A+';
  else if(energy >= cfg.endingThresholds['A']) ending='A';
  else if(energy >= cfg.endingThresholds['B']) ending='B';
  else ending='C';
  Chain.set('bossEnding', ending);
  Chain.set('bossEnergyLeft', Math.round(energy));
  const labels = { 'A+':'A+ SCALE TRIUMPH','A':'A · DEFLECTED','B':'B · GRID FLICKER','C':'C · BLACKOUT' };
  const colors = { 'A+':'#ffd700','A':'#7effb2','B':'#64d8ff','C':'#ff5c7a' };
  const card = document.getElementById('endCard');
  card.style.display='block'; card.style.borderColor = colors[ending];
  document.getElementById('endTitle').textContent = '✨ ENDING: '+labels[ending];
  document.getElementById('endTitle').style.color = colors[ending];
  document.getElementById('endBody').innerHTML = `Energy เหลือ: <b>${Math.round(energy)}</b> · ตอบไป ${answered} ข้อ`;
  if(window.MysteryBox && MysteryBox.roll){
    const wrongs = ending==='A+'?0:(ending==='A'?2:(ending==='B'?4:6));
    setTimeout(()=>MysteryBox.roll({wrongs, page:'p24'}), 800);
  }
  if(window.Coin){
    if(ending==='A+') Coin.awardPerfect && Coin.awardPerfect('p24');
    else if(ending==='A'){ const k='cosmosLog_ep06_bossA'; if(!localStorage.getItem(k)){ Coin.add(40,'p24:A'); localStorage.setItem(k,'1'); } }
    else if(ending==='B'){ const k='cosmosLog_ep06_bossB'; if(!localStorage.getItem(k)){ Coin.add(15,'p24:B'); localStorage.setItem(k,'1'); } }
  }
  Submit.record('p24', { ending, energy:Math.round(energy), answered });
  Gate.markSubmitted();
  const btn = document.getElementById('nextBtn'); btn.disabled=false; btn.textContent='▶ ดู Ending';
}

document.getElementById('startBtn').onclick = () => {
  document.getElementById('startBtn').style.display='none';
  loadZonePool(1); Chain.set('bossWave',1);
  renderPowerBar(); showQ(); startCharge();
};
setTimeout(renderPowerBar, 300);
updateHud();
setTimeout(()=>{ Gate.wireButton('p24', document.getElementById('nextBtn'), 'p25-rescue-ending.html', { requireSubmit:true }); }, 200);
</script>
</body></html>
